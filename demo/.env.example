# LienFi Demo — Environment Variables
# Copy to .env and fill in values

# --- RPC ---
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- API ---
API_URL=https://sealbid.onrender.com
API_KEY=your-api-key

# --- Contract Addresses (from deployment) ---
MOCK_USDC_ADDRESS=0x...
LENDING_POOL_ADDRESS=0x...
LOAN_MANAGER_ADDRESS=0x...
PROPERTY_NFT_ADDRESS=0x...
LIENFI_AUCTION_ADDRESS=0x...
CL_USDC_ADDRESS=0x...

# --- Actor Private Keys (Sepolia testnet only!) ---
LENDER_PRIVATE_KEY=0x...
BORROWER_PRIVATE_KEY=0x...
BIDDER_A_PRIVATE_KEY=0x...
BIDDER_B_PRIVATE_KEY=0x...

# --- Plaid Sandbox ---
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# --- Demo Parameters (optional, defaults shown) ---
# POOL_FUNDING_AMOUNT=500000000000
# LOAN_REQUEST_AMOUNT=100000000
# LOAN_TENURE_MONTHS=360
# LOAN_NONCE=10
# BID_A_AMOUNT=150000000
# BID_B_AMOUNT=120000000
# BIDDER_DEPOSIT_AMOUNT=200000000
# PROPERTY_ID=PROP-001
